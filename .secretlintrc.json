{
  "ignorePaths": [
    "node_modules/**",
    ".git/**",
    "dist/**",
    "build/**"
  ],
  "allowedExtensions": [
    ".js",
    ".ts",
    ".jsx",
    ".tsx",
    ".env",
    ".swift"
  ],
  "maxFileSizeKB": 256,
  "entropyThreshold": 3.8,
  "failOn": "high",
  "suppressions": [],
  "ignoreDetectors": []
}
